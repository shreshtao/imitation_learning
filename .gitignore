# Python venv + caches
.venv/
__pycache__/
*.pyc
.ipynb_checkpoints/

# Nix dev-shell runtime artifacts (recreated by the flake shellHook on `nix develop`)
.driver-libs/
.sys-headers/

# Datasets — downloaded via ./download_data.sh (large, research-only, not redistributable)
robomimic/datasets/
*.hdf5

# Saved rollout media — regenerated by the notebooks; the GIFs shown on GitHub are
# embedded directly in the .ipynb outputs, so nothing here needs committing.
videos/
bc_output/

# Jupyter "Make a Copy" duplicates
*-Copy*.ipynb
